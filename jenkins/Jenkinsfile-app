pipeline {
    agent any

    environment {
        AWS_REGION    = 'ap-south-1'
        AWS_ACCOUNT   = '957948932374'
        ECR_BASE      = "${AWS_ACCOUNT}.dkr.ecr.${AWS_REGION}.amazonaws.com/task-management"
        CLUSTER_NAME  = 'task-management-eks'
        NAMESPACE     = 'task-management'
        IMAGE_TAG     = "${BUILD_NUMBER}"
        GIT_REPO      = 'https://github.com/Raghukongala/demo-app.git'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: "${GIT_REPO}"
            }
        }

        stage('ECR Login') {
            steps {
                sh 'aws ecr get-login-password --region $AWS_REGION | docker login --username AWS --password-stdin $ECR_BASE'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh "${tool 'SonarScanner'}/bin/sonar-scanner"
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 2, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: false
                }
            }
        }

        stage('Install Trivy') {
            steps {
                sh '''
                    which trivy || (
                        curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh -s -- -b $HOME/bin
                        export PATH=$PATH:$HOME/bin
                    )
                    export PATH=$PATH:$HOME/bin
                    trivy --version
                '''
            }
        }

        stage('Build & Push Images') {
            parallel {
                stage('frontend') {
                    steps {
                        dir('frontend') {
                            sh '''
                                docker build -t $ECR_BASE/frontend:$IMAGE_TAG .
                                docker push $ECR_BASE/frontend:$IMAGE_TAG
                                docker tag $ECR_BASE/frontend:$IMAGE_TAG $ECR_BASE/frontend:latest
                                docker push $ECR_BASE/frontend:latest
                            '''
                        }
                    }
                }
                stage('task-service') {
                    steps {
                        dir('task-service') {
                            sh '''
                                docker build -t $ECR_BASE/task-service:$IMAGE_TAG .
                                docker push $ECR_BASE/task-service:$IMAGE_TAG
                                docker tag $ECR_BASE/task-service:$IMAGE_TAG $ECR_BASE/task-service:latest
                                docker push $ECR_BASE/task-service:latest
                            '''
                        }
                    }
                }
                stage('user-service') {
                    steps {
                        dir('user-service') {
                            sh '''
                                docker build -t $ECR_BASE/user-service:$IMAGE_TAG .
                                docker push $ECR_BASE/user-service:$IMAGE_TAG
                                docker tag $ECR_BASE/user-service:$IMAGE_TAG $ECR_BASE/user-service:latest
                                docker push $ECR_BASE/user-service:latest
                            '''
                        }
                    }
                }
                stage('notification-service') {
                    steps {
                        dir('notification-service') {
                            sh '''
                                docker build -t $ECR_BASE/notification-service:$IMAGE_TAG .
                                docker push $ECR_BASE/notification-service:$IMAGE_TAG
                                docker tag $ECR_BASE/notification-service:$IMAGE_TAG $ECR_BASE/notification-service:latest
                                docker push $ECR_BASE/notification-service:latest
                            '''
                        }
                    }
                }
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh '''
                    export PATH=$PATH:$HOME/bin
                    echo "=== Scanning frontend ==="
                    trivy image --exit-code 0 --severity HIGH,CRITICAL --no-progress $ECR_BASE/frontend:$IMAGE_TAG

                    echo "=== Scanning task-service ==="
                    trivy image --exit-code 0 --severity HIGH,CRITICAL --no-progress $ECR_BASE/task-service:$IMAGE_TAG

                    echo "=== Scanning user-service ==="
                    trivy image --exit-code 0 --severity HIGH,CRITICAL --no-progress $ECR_BASE/user-service:$IMAGE_TAG

                    echo "=== Scanning notification-service ==="
                    trivy image --exit-code 0 --severity HIGH,CRITICAL --no-progress $ECR_BASE/notification-service:$IMAGE_TAG
                '''
            }
        }

        stage('Update Image Tags in Repo') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'github-credentials', usernameVariable: 'GIT_USER', passwordVariable: 'GIT_TOKEN')]) {
                    sh '''
                        sed -i "s|$ECR_BASE/frontend:.*|$ECR_BASE/frontend:$IMAGE_TAG|g" k8s/frontend.yaml
                        sed -i "s|$ECR_BASE/task-service:.*|$ECR_BASE/task-service:$IMAGE_TAG|g" k8s/task-service.yaml
                        sed -i "s|$ECR_BASE/user-service:.*|$ECR_BASE/user-service:$IMAGE_TAG|g" k8s/user-service.yaml
                        sed -i "s|$ECR_BASE/notification-service:.*|$ECR_BASE/notification-service:$IMAGE_TAG|g" k8s/notification-service.yaml
                        sed -i "s|$ECR_BASE/frontend:.*|$ECR_BASE/frontend:$IMAGE_TAG|g" k8s/rollouts.yaml
                        sed -i "s|$ECR_BASE/user-service:.*|$ECR_BASE/user-service:$IMAGE_TAG|g" k8s/rollouts.yaml
                        sed -i "s|$ECR_BASE/task-service:.*|$ECR_BASE/task-service:$IMAGE_TAG|g" k8s/rollouts.yaml
                        sed -i "s|$ECR_BASE/notification-service:.*|$ECR_BASE/notification-service:$IMAGE_TAG|g" k8s/rollouts.yaml

                        git config user.email "jenkins@raghu.buzz"
                        git config user.name "Jenkins"
                        git remote set-url origin https://$GIT_USER:$GIT_TOKEN@github.com/Raghukongala/demo-app.git
                        git add k8s/frontend.yaml k8s/task-service.yaml k8s/user-service.yaml k8s/notification-service.yaml k8s/rollouts.yaml
                        git commit -m "Update image tags to build $IMAGE_TAG [skip ci]"
                        git push origin main
                    '''
                }
            }
        }

        stage('Verify ArgoCD Sync') {
            steps {
                sh '''
                    aws eks update-kubeconfig --region $AWS_REGION --name $CLUSTER_NAME
                    sleep 30
                    kubectl get application task-management -n argocd
                    kubectl rollout status deployment/frontend -n $NAMESPACE --timeout=120s
                    kubectl rollout status deployment/task-service -n $NAMESPACE --timeout=120s
                    kubectl rollout status deployment/user-service -n $NAMESPACE --timeout=120s
                    kubectl rollout status deployment/notification-service -n $NAMESPACE --timeout=120s
                '''
            }
        }
    }

    post {
        failure {
            echo 'App deployment failed!'
        }
        success {
            echo "App deployed successfully via ArgoCD! Build: ${BUILD_NUMBER}"
        }
    }
}
